{
  "realm": "starter-realm",
  "displayName": "Keycloak Starter Realm",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "refreshTokenMaxReuse": 0,

  "roles": {
    "realm": [
      {
        "name": "ROLE_ADMIN",
        "description": "Full access - can manage users, roles, and all resources"
      },
      {
        "name": "ROLE_MANAGER",
        "description": "Can manage resources but not users or roles"
      },
      {
        "name": "ROLE_USER",
        "description": "Standard user - can access own resources only"
      }
    ]
  },

  "clients": [
    {
      "clientId": "backend-service",
      "name": "Spring Boot Backend Service",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "backend-secret-1234",
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    },
    {
      "clientId": "postman-client",
      "name": "Postman Test Client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "postman-secret-5678",
      "publicClient": false,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    }
  ],

  "users": [
    {
      "username": "admin-user",
      "email": "admin@starter.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_ADMIN", "ROLE_USER"]
    },
    {
      "username": "manager-user",
      "email": "manager@starter.com",
      "firstName": "Manager",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "manager123",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_MANAGER", "ROLE_USER"]
    },
    {
      "username": "regular-user",
      "email": "user@starter.com",
      "firstName": "Regular",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": ["ROLE_USER"]
    }
  ]
}
